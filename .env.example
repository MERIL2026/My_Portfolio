# =====================================================================
# ENVIRONMENT VARIABLES — EXAMPLE / TEMPLATE
# =====================================================================
# DO NOT put real secrets here. This file IS committed to Git.
# Copy this file to ".env" and fill in your actual values.
#   cp .env.example .env
# =====================================================================

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# APP_URL: The URL where this app is hosted (e.g. your Vercel deployment URL).
APP_URL="https://your-app.vercel.app"

# SUPABASE: Connection details for your Supabase project.
# Get these from: Supabase Dashboard → Project Settings → API
# The VITE_ prefix exposes them to the frontend (intentional — Supabase anon key is
# safe to be public; access is controlled by Row Level Security in Supabase).
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# VERCEL API (For Analytics Export)
# Generate a token at: Vercel Dashboard → Account Settings → Tokens
# VERCEL_PROJECT_ID can be found in Vercel Dashboard → Project Settings → General
# These must ONLY be set as Server-Side variables in Vercel (do NOT prefix with VITE_)
VERCEL_API_TOKEN="your-vercel-token-here"
VERCEL_PROJECT_ID="prj_xxxxxxxxxxxx"
# VERCEL_TEAM_ID="team_xxxxxxxxxxxx" # Optional, only if the project is under a team

# ADMIN DASHBOARD: Password for the admin panel at /admin.
# Use a strong, unique password. NEVER use a simple fallback here.
# Required — the server will refuse to start/authenticate if this is missing.
ADMIN_PASSWORD="your-strong-admin-password-here"

# EMAILJS: Client-side email delivery service.
# Get these from: https://dashboard.emailjs.com → Email Services / Email Templates
# The Public Key is intentionally exposed to the browser (EmailJS is a client-side SDK).
VITE_EMAILJS_SERVICE_ID="service_xxxxxxxx"
VITE_EMAILJS_TEMPLATE_ID="template_xxxxxxxx"
VITE_EMAILJS_PUBLIC_KEY="your-public-key-here"

# RATE LIMITING (all optional — sensible defaults apply if omitted)
# RATE_LIMIT_AUTH_WINDOW_MS=60000
# RATE_LIMIT_AUTH_MAX_REQS=5
# RATE_LIMIT_AUTH_BASE_DELAY_MS=60000
# RATE_LIMIT_PUBLIC_WINDOW_MS=60000
# RATE_LIMIT_PUBLIC_MAX_REQS=60
# RATE_LIMIT_AUTHED_WINDOW_MS=60000
# RATE_LIMIT_AUTHED_MAX_REQS=300
