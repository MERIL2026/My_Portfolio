# =====================================================================
# ENVIRONMENT VARIABLES — EXAMPLE / TEMPLATE
# =====================================================================
# DO NOT put real secrets here. This file IS committed to Git.
# Copy this file to ".env" and fill in your actual values.
#   cp .env.example .env
# =====================================================================

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# APP_URL: The URL where this app is hosted (e.g. your Vercel deployment URL).
APP_URL="https://your-app.vercel.app"

# SUPABASE: Connection details for your Supabase project.
# Get these from: Supabase Dashboard → Project Settings → API
# The VITE_ prefix exposes them to the frontend (safe — Supabase RLS protects data).
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"
